# Copy this file to .env.local and fill in the values from your Firebase
# project's "Your apps" (web) settings. These are not secret -- Firebase's
# security comes from Firestore rules and authorized domains, not from
# hiding these values -- but they're kept out of the repo anyway so each
# environment (local dev, CI) supplies its own.
#
# Leave them unset to run the app in guest-only (local storage) mode with
# no Google sign-in, which is the default for local development.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
