{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gre-quant-app/skill.schema.json",
  "title": "Skill",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "area", "topic", "name", "prerequisites", "description"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "area": { "enum": ["Arithmetic", "Algebra", "Geometry", "Data Analysis"] },
    "topic": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "description": { "type": "string", "minLength": 1 }
  }
}
