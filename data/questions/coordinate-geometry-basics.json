        { "kind": "line", "from": { "x": 90, "y": 105 }, "to": { "x": 150, "y": 60 }, "dashed": true },
        { "kind": "circle", "center": { "x": 90, "y": 105 }, "radius": 2.5 },
        { "kind": "circle", "center": { "x": 150, "y": 60 }, "radius": 2.5 },
        { "kind": "label", "at": { "x": 95, "y": 118 }, "text": "A (2, 3)" },
        { "kind": "label", "at": { "x": 155, "y": 55 }, "text": "B (6, 6)" }
      ]
    },
    "answer": 5,
    "solutionStandard": "\\(d = \\sqrt{(6-2)^2+(6-3)^2} = \\sqrt{16+9} = \\sqrt{25} = 5\\).",
    "timeTargetSec": 50
  },
