    "difficulty": 1,
    "stem": "In the figure below, \\(O\\) is the center of the circle with radius 7, and the central angle shown is 60°. What is the length of the arc (in terms of \\(\\pi\\))?",
    "figure": {
      "viewBox": "0 0 200 160",
      "elements": [
        { "kind": "circle", "center": { "x": 100, "y": 90 }, "radius": 70 },
        { "kind": "line", "from": { "x": 100, "y": 90 }, "to": { "x": 170, "y": 90 } },
        { "kind": "line", "from": { "x": 100, "y": 90 }, "to": { "x": 135, "y": 29 } },
        { "kind": "label", "at": { "x": 95, "y": 85 }, "text": "O" },
        { "kind": "label", "at": { "x": 108, "y": 65 }, "text": "60°" }
      ]
    },
    "options": [
      { "id": "A", "text": "\\(\\frac{7\\pi}{3}\\)" },
      { "id": "B", "text": "\\(\\frac{7\\pi}{6}\\)" },
      { "id": "C", "text": "\\(7\\pi\\)" },
      { "id": "D", "text": "\\(\\frac{14\\pi}{3}\\)" },
      { "id": "E", "text": "\\(\\frac{49\\pi}{6}\\)" }
    ],
    "answer": "A",
    "solutionStandard": "Arc length \\(= \\dfrac{60}{360} \\times 2\\pi(7) = \\dfrac{1}{6} \\times 14\\pi = \\dfrac{14\\pi}{6} = \\dfrac{7\\pi}{3}\\).",
    "timeTargetSec": 65
  },
  {
