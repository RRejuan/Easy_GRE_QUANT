    "secondarySkills": [],
    "difficulty": 4,
    "stem": "Two radii of a circle with radius 10 form a central angle of 120°, creating a sector. What is the perimeter of the sector (the two radii plus the arc), in terms of \\(\\pi\\)?",
    "options": [
      { "id": "A", "text": "\\(20 + \\frac{10\\pi}{3}\\)" },
      { "id": "B", "text": "\\(20 + \\frac{20\\pi}{3}\\)" },
