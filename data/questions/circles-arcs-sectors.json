      { "id": "D", "text": "\\(20\\pi\\)" },
      { "id": "E", "text": "\\(20 + 10\\pi\\)" }
    ],
    "answer": "B",
    "solutionStandard": "Arc length \\(=\\dfrac{120}{360}\\times2\\pi(10)=\\dfrac{1}{3}\\times20\\pi=\\dfrac{20\\pi}{3}\\). Perimeter \\(= 10+10+\\dfrac{20\\pi}{3}=20+\\dfrac{20\\pi}{3}\\).",
    "timeTargetSec": 85
  },
