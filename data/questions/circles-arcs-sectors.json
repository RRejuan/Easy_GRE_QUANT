  {
    "id": "circles-arcs-sectors-007",
    "type": "MultiMC",
    "primarySkill": "circles-arcs-sectors",
    "secondarySkills": [],
    "difficulty": 3,
    "stem": "A circle has radius 4. Which of the following are possible areas of a sector of this circle? Select all that apply.",
    "options": [
      { "id": "A", "text": "\\(2\\pi\\)" },
      { "id": "B", "text": "\\(8\\pi\\)" },
      { "id": "C", "text": "\\(16\\pi\\)" },
      { "id": "D", "text": "\\(20\\pi\\)" }
    ],
    "answer": ["A", "B", "C"],
    "solutionStandard": "The full circle's area is \\(\\pi(4)^2=16\\pi\\), so any sector area must be between 0 and \\(16\\pi\\), inclusive. \\(2\\pi\\), \\(8\\pi\\), and \\(16\\pi\\) (the whole circle) are all valid; \\(20\\pi\\) exceeds the full circle's area.",
    "timeTargetSec": 65
  },
