      {
        "id": "B",
        "text": "-5"
      },
      {
        "id": "C",
        "text": "-3"
      },
      {
        "id": "D",
        "text": "3"
      },
      {
        "id": "E",
        "text": "5"
      }
    ],
    "answer": "A",
    "solutionStandard": "Rewrite \\(3x-y=5\\) as \\(y=3x-5\\), slope 3. Parallel line: \\(y=3x+b\\). Plug in \\((2,-1)\\): \\(-1=3(2)+b\\), so \\(-1=6+b\\), giving \\(b=-7\\).",
    "timeTargetSec": 75
  },
