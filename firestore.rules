rules_version = '2';

// Paste this into Firebase console -> Firestore Database -> Rules.
//
// Every signed-in user gets their own document tree under
// /users/{their-uid}/... and can only ever read or write their own data.
// No one (including other signed-in users) can read or write anyone
// else's progress. Unauthenticated requests are rejected entirely --
// guests who haven't signed in never touch Firestore, they stay on
// local storage.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Question reports ("this question is wrong" / "explain this better").
    // Anyone may file one -- guests included, since errors should be
    // reportable without an account -- but nobody can read, edit, or
    // delete them from the client. The owner reviews them in the
    // Firebase console (console access bypasses these rules).
    match /feedback/{reportId} {
      allow create: if request.resource.data.questionId is string
        && request.resource.data.questionId.size() <= 100
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }
  }
}
